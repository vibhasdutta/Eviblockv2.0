rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection rules
    match /users/{userId} {
      // Allow users to read their own profile
      allow read: if isOwner(userId);
      
      // Allow users to create their own profile during signup
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Allow users to update only their own profile
      // Prevent changing createdAt field
      allow update: if isOwner(userId) 
        && request.resource.data.createdAt == resource.data.createdAt;
      
      // Prevent users from deleting their profile
      allow delete: if false;
      
      // Video proof subcollection rules
      match /videoProof/{videoProofId} {
        // Allow users to read their own video proof records
        allow read: if isOwner(userId);
        
        // Allow users to create video proof during KYC verification
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasAll(['videoUrl', 'videoHash', 'timestamp'])
          && request.resource.data.videoHash is string
          && request.resource.data.videoHash.size() == 64; // SHA-256 hash length
        
        // Allow users to update only documentCid field after document upload
        allow update: if isOwner(userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['documentCid', 'updatedAt']);
        
        // Prevent deletion of video proof records
        allow delete: if false;
      }
    }
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
